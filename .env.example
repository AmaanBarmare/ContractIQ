# IBM Watsonx.ai — required for Extraction and Decision agents
# Get these from IBM Cloud → Watsonx → API Keys and your Watsonx project settings.
WATSONX_API_KEY=
WATSONX_URL=https://us-south.ml.cloud.ibm.com
WATSONX_PROJECT_ID=

# Optional: override the default foundation model.
# Default is ibm/granite-3-8b-instruct. If that isn't available in your
# Watsonx project, known working alternatives include:
#   ibm/granite-3-2b-instruct
#   ibm/granite-13b-instruct-v2
#   meta-llama/llama-3-3-70b-instruct
# WATSONX_MODEL_ID=ibm/granite-3-8b-instruct
