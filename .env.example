# IBM Watsonx Orchestrate — required for agent orchestration
ORCHESTRATE_API_KEY=
ORCHESTRATE_INSTANCE_URL=

# Anthropic Claude — required for Extraction and Decision agents
ANTHROPIC_API_KEY=

# Optional: override the default Claude model.
# Default is claude-sonnet-4-6.
# ANTHROPIC_MODEL_ID=claude-sonnet-4-6

# Redis (local)
REDIS_URL=redis://localhost:6379

# App
SECRET_KEY=your-secret-key-here
